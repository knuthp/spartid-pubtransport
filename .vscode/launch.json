{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python poller",
            "type": "debugpy",
            "request": "launch",
            "program": "spartid_pubtransport/poller.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit debug",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "spartid_pubtransport/stapp/stapp.py"
            ]
        },
        {
            "name": "fastapi api.y",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "spartid_pubtransport.api.api:app",
                "--reload",
                "--port=5000"
            ],
            "env": {
                "SQLALCHEMY_DATABASE_URI": "postgresql://postgres:postgres@localhost:9202/spartid_pubtransport",
            }
        }
    ]
}
